                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT r.Rental_ID,
       r.Rental_Start_Date, r.Rental_End_Date,
       r.Rental_Duration_Days, r.Branch_Name,
       r.Car_Brand, r.Car_Model, r.Vehicle_Year,
       r.Mileage_KM, r.Payment_Method, r.Insurance_Type,
       r.Daily_Rate_LKR, r.Rental_Cost_LKR,
       r.Insurance_Fee_LKR, r.Additional_Driver_Fee_LKR,
       r.Fuel_Charge_LKR, r.Total_Amount_LKR,
       r.Staff_ID, r.Vehicle_Status,
       c.Customer_Type, c.Customer_Gender,
       c.Customer_Age, c.License_Type
FROM CarRental_Staging.dbo.stg_RentalTransactions r
JOIN CarRental_Staging.dbo.stg_CustomerData c
  ON r.Rental_ID = c.Rental_ID</property>
