    <DTS:Executable
      DTS:refId="Package\Load DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{81193F5C-A574-4672-9115-03F9850C7FCC}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{69930B72-B66F-4ADE-AD76-C07900ADB760}"
          SQLTask:SqlStatementSource="USE CarRental_DW;&#xA;GO&#xA;&#xA;-- Clear existing data first&#xA;TRUNCATE TABLE DimDate;&#xA;GO&#xA;&#xA;DECLARE @StartDate DATE = '2022-01-01';&#xA;DECLARE @EndDate   DATE = '2023-06-30';&#xA;DECLARE @CurrentDate DATE = @StartDate;&#xA;&#xA;WHILE @CurrentDate &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO DimDate (&#xA;        DateKey,&#xA;        FullDate,&#xA;        DayOfMonth,&#xA;        DayName,&#xA;        DayOfWeek,&#xA;        DayOfYear,&#xA;        WeekOfYear,&#xA;        MonthNumber,&#xA;        MonthName,&#xA;        Quarter,&#xA;        QuarterName,&#xA;        Year,&#xA;        IsWeekend,&#xA;        IsHoliday&#xA;    )&#xA;    VALUES (&#xA;        -- DateKey format: YYYYMMDD  e.g. 20220101&#xA;        CAST(FORMAT(@CurrentDate, 'yyyyMMdd') AS INT),&#xA;&#xA;        -- Full date&#xA;        @CurrentDate,&#xA;&#xA;        -- Day of month (1–31)&#xA;        DAY(@CurrentDate),&#xA;&#xA;        -- Day name e.g. Monday&#xA;        DATENAME(WEEKDAY, @CurrentDate),&#xA;&#xA;        -- Day of week (1=Sunday, 7=Saturday)&#xA;        DATEPART(WEEKDAY, @CurrentDate),&#xA;&#xA;        -- Day of year (1–365)&#xA;        DATEPART(DAYOFYEAR, @CurrentDate),&#xA;&#xA;        -- Week number of year&#xA;        DATEPART(WEEK, @CurrentDate),&#xA;&#xA;        -- Month number (1–12)&#xA;        MONTH(@CurrentDate),&#xA;&#xA;        -- Month name e.g. January&#xA;        DATENAME(MONTH, @CurrentDate),&#xA;&#xA;        -- Quarter (1–4)&#xA;        DATEPART(QUARTER, @CurrentDate),&#xA;&#xA;        -- Quarter name e.g. Q1&#xA;        'Q' + CAST(DATEPART(QUARTER, @CurrentDate) AS VARCHAR(1)),&#xA;&#xA;        -- Year e.g. 2022&#xA;        YEAR(@CurrentDate),&#xA;&#xA;        -- IsWeekend: 1 if Saturday or Sunday&#xA;        CASE WHEN DATEPART(WEEKDAY, @CurrentDate) IN (1, 7) THEN 1 ELSE 0 END,&#xA;&#xA;        -- IsHoliday: 0 by default (can be updated manually later)&#xA;        0&#xA;    );&#xA;&#xA;    -- Move to the next day&#xA;    SET @CurrentDate = DATEADD(DAY, 1, @CurrentDate);&#xA;END;&#xA;GO&#xA;&#xA;-- Verify: should return 546 rows (Jan 2022 to Jun 2023)&#xA;SELECT COUNT(*) AS TotalDays FROM DimDate;&#xA;SELECT TOP 5 * FROM DimDate ORDER BY DateKey ASC;&#xA;SELECT TOP 5 * FROM DimDate ORDER BY DateKey DESC;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
