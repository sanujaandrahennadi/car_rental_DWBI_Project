                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">City == "Negombo" || City == "Colombo" ? "Western" : City == "Kandy" ? "Central" : City == "Jaffna" ? "Northern" : City == "Galle" ? "Southern" : "Other"</property>
                      </properties>
                    </outputColumn>
