                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">#{Package\Load DimBranch\Derive City.Outputs[Derived Column Output].Columns[City]} == "Negombo" || #{Package\Load DimBranch\Derive City.Outputs[Derived Column Output].Columns[City]} == "Colombo" ? "Western" : #{Package\Load DimBranch\Derive City.Outputs[Derived Column Output].Columns[City]} == "Kandy" ? "Central" : #{Package\Load DimBranch\Derive City.Outputs[Derived Column Output].Columns[City]} == "Jaffna" ? "Northern" : #{Package\Load DimBranch\Derive City.Outputs[Derived Column Output].Columns[City]} == "Galle" ? "Southern" : "Other"</property>
