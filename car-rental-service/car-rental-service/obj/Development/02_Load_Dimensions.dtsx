                      name="City"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">[FINDSTRING](#{Package\Load DimBranch\OLE DB Source.Outputs[OLE DB Source Output].Columns[Branch_Name]},"Negombo",1) &gt; 0 ? "Negombo" : [FINDSTRING](#{Package\Load DimBranch\OLE DB Source.Outputs[OLE DB Source Output].Columns[Branch_Name]},"Colombo",1) &gt; 0 ? "Colombo" : [FINDSTRING](#{Package\Load DimBranch\OLE DB Source.Outputs[OLE DB Source Output].Columns[Branch_Name]},"Kandy",1) &gt; 0 ? "Kandy" : [FINDSTRING](#{Package\Load DimBranch\OLE DB Source.Outputs[OLE DB Source Output].Columns[Branch_Name]},"Jaffna",1) &gt; 0 ? "Jaffna" : [FINDSTRING](#{Package\Load DimBranch\OLE DB Source.Outputs[OLE DB Source Output].Columns[Branch_Name]},"Galle",1) &gt; 0 ? "Galle" : "Other"</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">FINDSTRING(Branch_Name,"Negombo",1) &gt; 0 ? "Negombo" : FINDSTRING(Branch_Name,"Colombo",1) &gt; 0 ? "Colombo" : FINDSTRING(Branch_Name,"Kandy",1) &gt; 0 ? "Kandy" : FINDSTRING(Branch_Name,"Jaffna",1) &gt; 0 ? "Jaffna" : FINDSTRING(Branch_Name,"Galle",1) &gt; 0 ? "Galle" : "Other"</property>
